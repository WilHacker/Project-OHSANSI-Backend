{
  "info": {
    "name": "OHSANSI API",
    "description": "Colección completa de la API REST del sistema de olimpiadas OHSANSI.\n\n**Variables de entorno necesarias:**\n- `baseUrl` → http://localhost:8000/api/v1\n- `token`   → se llena automáticamente al hacer login\n\n**Cómo usar:**\n1. Importar este archivo en Postman\n2. Crear un Environment con `baseUrl` = http://localhost:8000/api/v1\n3. Ejecutar `POST /auth/login` — el token se guarda automáticamente",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    { "key": "baseUrl", "value": "http://localhost:8000/api/v1", "type": "string" },
    { "key": "token",   "value": "", "type": "string" }
  ],
  "auth": {
    "type": "bearer",
    "bearer": [{ "key": "token", "value": "{{token}}", "type": "string" }]
  },
  "item": [

    {
      "name": "01 · Autenticación",
      "item": [
        {
          "name": "Login",
          "event": [{
            "listen": "test",
            "script": {
              "exec": [
                "const json = pm.response.json();",
                "if (json.token) {",
                "  pm.collectionVariables.set('token', json.token);",
                "  pm.environment.set('token', json.token);",
                "}"
              ],
              "type": "text/javascript"
            }
          }],
          "request": {
            "auth": { "type": "noauth" },
            "method": "POST",
            "url": "{{baseUrl}}/auth/login",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"admin@ohsansi.bo\",\n  \"password\": \"secreto123\"\n}"
            },
            "description": "Throttle: 10 intentos/min. El token se guarda automáticamente en la variable de colección."
          }
        },
        {
          "name": "Perfil del usuario autenticado",
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/auth/me",
            "description": "Devuelve los datos del usuario autenticado con sus roles y permisos."
          }
        },
        {
          "name": "Mis acciones disponibles",
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/usuario/mis-acciones/usuario/1",
            "description": "Reemplazar '1' con el id_usuario. Devuelve array de códigos de acción habilitados."
          }
        }
      ]
    },

    {
      "name": "02 · Sistema",
      "item": [
        {
          "name": "Estado del sistema",
          "request": {
            "auth": { "type": "noauth" },
            "method": "GET",
            "url": "{{baseUrl}}/sistema/estado"
          }
        },
        {
          "name": "Health check",
          "request": {
            "auth": { "type": "noauth" },
            "method": "GET",
            "url": "{{baseUrl}}/test"
          }
        }
      ]
    },

    {
      "name": "03 · Olimpiadas",
      "item": [
        {
          "name": "Olimpiada actual (público)",
          "request": {
            "auth": { "type": "noauth" },
            "method": "GET",
            "url": "{{baseUrl}}/olimpiadas/actual"
          }
        },
        {
          "name": "Olimpiadas anteriores (público)",
          "request": {
            "auth": { "type": "noauth" },
            "method": "GET",
            "url": "{{baseUrl}}/olimpiadas/anteriores"
          }
        },
        {
          "name": "Gestiones / años (público)",
          "request": {
            "auth": { "type": "noauth" },
            "method": "GET",
            "url": "{{baseUrl}}/gestiones"
          }
        },
        {
          "name": "Listar todas las olimpiadas",
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/olimpiadas"
          }
        },
        {
          "name": "Crear olimpiada",
          "request": {
            "method": "POST",
            "url": "{{baseUrl}}/olimpiadas",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"nombre\": \"Olimpiada Científica Estudiantil 2025\",\n  \"gestion\": \"2025\"\n}"
            }
          }
        },
        {
          "name": "Crear olimpiada (admin — puede activar de inmediato)",
          "request": {
            "method": "POST",
            "url": "{{baseUrl}}/olimpiadas/admin",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"nombre\": \"Olimpiada Científica Estudiantil 2025\",\n  \"gestion\": \"2025\",\n  \"estado\": true\n}",
              "options": { "raw": { "language": "json" } }
            },
            "description": "estado:true activa esta olimpiada y desactiva todas las demás."
          }
        },
        {
          "name": "Activar olimpiada",
          "request": {
            "method": "PATCH",
            "url": "{{baseUrl}}/olimpiadas/1/activar",
            "description": "Reemplazar '1' con el id de la olimpiada."
          }
        }
      ]
    },

    {
      "name": "04 · Competencias",
      "item": [
        {
          "name": "Listar competencias",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{baseUrl}}/competencias?por_pagina=15",
              "host": ["{{baseUrl}}"],
              "path": ["competencias"],
              "query": [{ "key": "por_pagina", "value": "15" }]
            }
          }
        },
        {
          "name": "Ver competencia",
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/competencias/1"
          }
        },
        {
          "name": "Crear competencia",
          "request": {
            "method": "POST",
            "url": "{{baseUrl}}/competencias",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"id_fase_global\": 1,\n  \"id_area_nivel\": 3,\n  \"fecha_inicio\": \"2025-08-01\",\n  \"fecha_fin\": \"2025-08-30\",\n  \"criterio_clasificacion\": \"suma_ponderada\"\n}",
              "options": { "raw": { "language": "json" } }
            },
            "description": "criterio_clasificacion: 'suma_ponderada' | 'promedio_simple' | 'manual'"
          }
        },
        {
          "name": "Actualizar competencia",
          "request": {
            "method": "PUT",
            "url": "{{baseUrl}}/competencias/1",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"fecha_inicio\": \"2025-08-05\",\n  \"fecha_fin\": \"2025-08-25\",\n  \"criterio_clasificacion\": \"promedio_simple\"\n}"
            }
          }
        },
        {
          "name": "Eliminar competencia",
          "request": {
            "method": "DELETE",
            "url": "{{baseUrl}}/competencias/1"
          }
        },
        {
          "name": "▶ Publicar competencia",
          "request": {
            "method": "PATCH",
            "url": "{{baseUrl}}/competencias/1/publicar",
            "description": "Estado: borrador → publicada"
          }
        },
        {
          "name": "▶ Iniciar competencia",
          "request": {
            "method": "PATCH",
            "url": "{{baseUrl}}/competencias/1/iniciar",
            "description": "Estado: publicada → en_proceso"
          }
        },
        {
          "name": "▶ Cerrar competencia",
          "request": {
            "method": "POST",
            "url": "{{baseUrl}}/competencias/1/cerrar",
            "description": "Estado: en_proceso → concluida. Requiere que TODOS los exámenes estén finalizados."
          }
        },
        {
          "name": "▶ Avalar competencia",
          "request": {
            "method": "POST",
            "url": "{{baseUrl}}/competencias/1/avalar",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"password_confirmacion\": \"mi_contraseña\"\n}"
            },
            "description": "Estado: concluida → avalada. Requiere la contraseña del responsable autenticado."
          }
        },
        {
          "name": "Áreas del responsable (olimpiada activa)",
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/competencias/responsable/1/areas/actuales",
            "description": "Reemplazar '1' con id_usuario del responsable."
          }
        },
        {
          "name": "Competencias por responsable y área",
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/competencias/responsable/1/area/2",
            "description": "Reemplazar IDs según corresponda."
          }
        },
        {
          "name": "Fases clasificatorias activas",
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/competencias/fase-global/clasificatoria/actuales"
          }
        }
      ]
    },

