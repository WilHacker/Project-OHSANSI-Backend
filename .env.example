APP_NAME="OHSANSI"
APP_ENV=local
APP_KEY=
APP_DEBUG=false
APP_TIMEZONE=America/La_Paz
APP_URL=http://localhost

APP_LOCALE=es
APP_FALLBACK_LOCALE=es
APP_FAKER_LOCALE=es_BO

APP_MAINTENANCE_DRIVER=file

PHP_CLI_SERVER_WORKERS=4

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
# En desarrollo: debug | En producción: error
LOG_LEVEL=debug

# -----------------------------------------------
# BASE DE DATOS
# Desarrollo: sqlite | Producción: mysql
# -----------------------------------------------
DB_CONNECTION=sqlite
# DB_HOST=127.0.0.1
# DB_PORT=3306
# DB_DATABASE=ohsansi
# DB_USERNAME=root
# DB_PASSWORD=

SESSION_DRIVER=database
SESSION_LIFETIME=480
SESSION_ENCRYPT=true
SESSION_PATH=/
SESSION_DOMAIN=null

# -----------------------------------------------
# BROADCASTING (WebSockets con Reverb)
# -----------------------------------------------
BROADCAST_CONNECTION=reverb

REVERB_APP_ID=
REVERB_APP_KEY=
REVERB_APP_SECRET=
REVERB_HOST=localhost
REVERB_PORT=8080
REVERB_SCHEME=http

VITE_REVERB_APP_KEY="${REVERB_APP_KEY}"
VITE_REVERB_HOST="${REVERB_HOST}"
VITE_REVERB_PORT="${REVERB_PORT}"
VITE_REVERB_SCHEME="${REVERB_SCHEME}"

# -----------------------------------------------
# COLAS DE TRABAJO
# Desarrollo: database | Producción: redis
# -----------------------------------------------
QUEUE_CONNECTION=database
# QUEUE_CONNECTION=redis  ← usar en producción

FILESYSTEM_DISK=local

CACHE_STORE=database
CACHE_PREFIX=ohsansi_

# -----------------------------------------------
# REDIS (recomendado para producción)
# -----------------------------------------------
REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

# -----------------------------------------------
# CORREO ELECTRÓNICO
# -----------------------------------------------
MAIL_MAILER=log
MAIL_SCHEME=null
MAIL_HOST=127.0.0.1
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_FROM_ADDRESS="noreply@ohsansi.edu.bo"
MAIL_FROM_NAME="${APP_NAME}"

# -----------------------------------------------
# CORS — Orígenes permitidos (separados por coma)
# -----------------------------------------------
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5173
# En producción: CORS_ALLOWED_ORIGINS=https://ohsansi.edu.bo

# -----------------------------------------------
# RATE LIMITING
# -----------------------------------------------
RATE_LIMIT_LOGIN=10
