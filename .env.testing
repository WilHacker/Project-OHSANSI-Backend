APP_NAME="OhSansiBackend"
APP_ENV=testing
APP_KEY="base64:mhhF/u99UAuZq3bAiL/3X/lsx8K8WBFKua8GJghXvMI="
APP_DEBUG=true
APP_URL=http://localhost:8000
APP_TIMEZONE=America/La_Paz

APP_LOCALE=es
APP_FALLBACK_LOCALE=es
APP_FAKER_LOCALE=es_BO

APP_MAINTENANCE_DRIVER=file
BCRYPT_ROUNDS=4
LOG_CHANNEL=stack
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

# -----------------------------------------------
# BASE DE DATOS
# Ejecutando los tests en WSL nativo: el MySQL de Docker
# esta expuesto en 127.0.0.1:3306, por eso usamos esa IP
# en lugar del hostname interno de Docker ("db").
# -----------------------------------------------
DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=ohsansi_db
DB_USERNAME=root
DB_PASSWORD=password

# -----------------------------------------------
# REDIS (no usado en tests: phpunit.xml fuerza array/sync)
# -----------------------------------------------
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

SESSION_DRIVER=array
SESSION_LIFETIME=480
SESSION_ENCRYPT=false

CACHE_STORE=array
CACHE_PREFIX=ohsansi_

QUEUE_CONNECTION=sync
FILESYSTEM_DISK=local

BROADCAST_CONNECTION=log

MAIL_MAILER=array

TELESCOPE_ENABLED=false
PULSE_ENABLED=false
RATE_LIMIT_LOGIN=10
